# =============================================================================
#  00-config.env — Variáveis de Ambiente Compartilhadas
# =============================================================================

# --- Domínios (Substitua pelos seus) ---
BASE_DOMAIN="seu-dominio.com"
CW_DOMAIN="sub_dominio-chatwoot.${BASE_DOMAIN}"
EVO_DOMAIN="sub_dominio-evolution.${BASE_DOMAIN}"
N8N_DOMAIN="sub_dominio-n8n.${BASE_DOMAIN}"
FB_DOMAIN="sub_dominio-files.${BASE_DOMAIN}"
NETDATA_DOMAIN="sub_dominio-netdata.${BASE_DOMAIN}"
UK_DOMAIN="sub_dominio-uptime.${BASE_DOMAIN}"
DZ_DOMAIN="sub_dominio-dozzle.${BASE_DOMAIN}"

# --- Credenciais e Chaves ---
# IMPORTANTE: Em produção, mude estas senhas!
PG_USER="postgres"
PG_PASSWORD="Zscansac123_"

CW_SECRET_KEY_BASE="Zscansac123_"
EVO_API_KEY="Zscansac123_"
FB_PASSWORD="zscansac123456"

# --- Configurações n8n ---
N8N_TIMEZONE="America/Sao_Paulo"
N8N_SECURE_COOKIE="false"

# --- Infraestrutura ---
DOCKER_NETWORK="proxy-network"
WATCHTOWER_INTERVAL="86400"

# --- Redis — Logical Databases (0–15) ---
REDIS_DB_CHATWOOT=0
REDIS_DB_EVOLUTION=1

# --- Portas Locais ---
PORT_CHATWOOT=3000
PORT_EVOLUTION=8080
PORT_N8N=5678
PORT_FILEBROWSER=8081
PORT_NETDATA=19999
PORT_UPTIME_KUMA=3001
PORT_DOZZLE=8083
PORT_REDIS=6379

# --- Imagens Docker ---
CW_IMAGE="chatwoot/chatwoot:latest"
EVO_IMAGE="evoapicloud/evolution-api:latest"
N8N_IMAGE="n8nio/n8n:latest"
FB_IMAGE="filebrowser/filebrowser:latest"
NETDATA_IMAGE="netdata/netdata:stable"
REDIS_IMAGE="redis:8.6-alpine"
WATCHTOWER_IMAGE="containrrr/watchtower:latest"
UPTIME_KUMA_IMAGE="louislam/uptime-kuma:1"
DOZZLE_IMAGE="amir20/dozzle:latest"
PG_IMAGE="sub_dominio-postgres:18.3"

# --- Configuração de Log Global (Docker) ---
DOCKER_LOG_CONFIG="logging:
      driver: 'json-file'
      options:
        max-size: '10m'
        max-file: '3'"
